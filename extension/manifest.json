{
  "manifest_version": 2,
  "name": "wf-themes",
  "version": "0.1.5",
  "description": "Theme injector for Discord, Claude, GitHub, Reddit, Teams, MTools, Outlook, and Proton Mail. Driven by the wmenu global theme selector via native messaging.",
  "homepage_url": "https://github.com/YannickHerrero/wf-themes",
  "applications": {
    "gecko": {
      "id": "wf-themes@yannick.herrero",
      "strict_min_version": "115.0"
    }
  },
  "permissions": [
    "tabs",
    "storage",
    "nativeMessaging",
    "*://discord.com/*",
    "*://claude.ai/*",
    "*://github.com/*",
    "*://*.github.com/*",
    "*://viewscreen.githubusercontent.com/*",
    "*://*.reddit.com/*",
    "*://teams.microsoft.com/*",
    "*://teams.live.com/*",
    "*://outlook.office.com/*",
    "*://outlook.office365.com/*",
    "*://outlook.live.com/*",
    "*://outlook.com/*",
    "*://mail.proton.me/*",
    "*://mtools-rho.vercel.app/*",
    "http://localhost:5175/*"
  ],
  "background": {
    "scripts": ["background.js"],
    "persistent": true
  },
  "browser_action": {
    "default_title": "wf-themes",
    "default_popup": "popup.html",
    "default_icon": "icons/icon.svg"
  },
  "icons": {
    "48": "icons/icon.svg",
    "96": "icons/icon.svg"
  }
}
